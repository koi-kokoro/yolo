SEMANTIC_DEPLOY_DIR=../training/loveda_semantic/artifacts/baseline_e50_i512_b2/deploy
# Relative paths are resolved from src/backend by Settings. The two model directories
# are resolved beneath this trusted root and rejected if they escape it.
MODEL_MANAGEMENT_TRUSTED_ROOT=../training/loveda_semantic
MODEL_MANAGEMENT_DEPLOY_DIR=artifacts/baseline_e50_i512_b2/deploy
MODEL_MANAGEMENT_TRAINING_RUN_DIR=runs/v2_hr1024_yolo26s_sem_full_e50_b4_m1_20260713T0336Z
MODEL_MANAGEMENT_STALE_SECONDS=1800
MODEL_MANAGEMENT_MAX_TEXT_BYTES=2097152
MODEL_MANAGEMENT_MAX_CSV_ROWS=1000
SEMANTIC_ENGINE=onnx
SEMANTIC_FALLBACK_TO_ONNX=true
SEMANTIC_VERIFY_SHA256=true
SEMANTIC_ONNX_SHA256=a5f7c887c20d628aabc2b8a834f6f376d4919687ebc7d2bc97f51fb9e413ba90
SEMANTIC_PT_SHA256=c147eff5a13d63183b4efb7d89417f7ace5354f708befd019908b5b8c2196ad9
SEMANTIC_INPUT_SIZE=512
SEMANTIC_MAX_UPLOAD_BYTES=20971520
SEMANTIC_MAX_DIMENSION=10000
SEMANTIC_MAX_PIXELS=40000000
SEMANTIC_EXECUTOR_WORKERS=1
SEMANTIC_QUEUE_SIZE=8
SEMANTIC_USER_ACTIVE_LIMIT=2
SEMANTIC_URL_EXPIRE_SECONDS=900
SEMANTIC_OVERLAY_ALPHA=0.45
SEMANTIC_PT_DEVICE=cuda:0
