APP_NAME=RSOD Agent Platform
APP_VERSION=0.1.0
DEBUG=true
LOG_LEVEL=INFO

DB_HOST=localhost
DB_PORT=5432
DB_NAME=rsod_agent
DB_USER=rsod_admin
DB_PASSWORD=rsod_admin

REDIS_HOST=localhost
REDIS_PORT=6379

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=rsod-agent-images
MINIO_SECURE=false

JWT_SECRET_KEY=rsod-dev-secret-key-2026
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# Build the package into the fixed current directory, then restart the backend.
# Relative paths are resolved from src/backend. The engine reads size/version/checksums
# from this self-contained package; it does not watch files or hot-reload models.
SEMANTIC_DEPLOY_DIR=../training/loveda_semantic/artifacts/current/deploy
# The two model-management directories are resolved beneath this trusted root and
# rejected if they escape it.
MODEL_MANAGEMENT_TRUSTED_ROOT=../training/loveda_semantic
MODEL_MANAGEMENT_DEPLOY_DIR=artifacts/current/deploy
MODEL_MANAGEMENT_TRAINING_RUN_DIR=runs/v2_hr1024_yolo26s_sem_full_e50_b4_m1_20260713T0336Z
MODEL_MANAGEMENT_STALE_SECONDS=1800
MODEL_MANAGEMENT_MAX_TEXT_BYTES=2097152
MODEL_MANAGEMENT_MAX_CSV_ROWS=1000
SEMANTIC_ENGINE=onnx
SEMANTIC_FALLBACK_TO_ONNX=true
SEMANTIC_VERIFY_SHA256=true
# Normally leave unset: SHA256SUMS.txt in SEMANTIC_DEPLOY_DIR is authoritative.
# Set only as an explicit emergency pin/override.
# SEMANTIC_ONNX_SHA256=
SEMANTIC_MAX_UPLOAD_BYTES=20971520
SEMANTIC_MAX_DIMENSION=10000
SEMANTIC_MAX_PIXELS=40000000
SEMANTIC_EXECUTOR_WORKERS=1
SEMANTIC_QUEUE_SIZE=8
SEMANTIC_USER_ACTIVE_LIMIT=2
SEMANTIC_URL_EXPIRE_SECONDS=900
SEMANTIC_OVERLAY_ALPHA=0.45
SEMANTIC_PT_DEVICE=cuda:0
