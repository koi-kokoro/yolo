# Local environment and secrets
**/.env
**/.env.*
!**/.env.example
!**/.env.sample
!**/.env.template
backend/**/*.pem
backend/**/*.key
backend/**/*.crt
backend/secrets/

# Python caches, tooling output, and virtual environments
**/__pycache__/
**/*.py[cod]
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/
**/.coverage
**/.coverage.*
**/htmlcov/
**/coverage.xml
**/.tox/
**/.nox/
**/.venv/
**/venv/
**/env/

# Backend runtime state
backend/logs/*
!backend/logs/.gitkeep
backend/**/*.log
backend/*.db
backend/*.sqlite
backend/*.sqlite3
backend/uploads/
backend/tmp/
backend/temp/
backend/.cache/

# Frontend dependencies, builds, caches, and preview output
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/coverage/
frontend/.vite/
frontend/.vitest/
frontend/.nyc_output/
frontend/playwright-report/
frontend/test-results/
frontend/preview*.log
frontend/vite-acceptance*.log
frontend/vite-acceptance*.pid

# Training datasets, generated runs, reports, and visualizations
training/history/
training/loveda_semantic/data/**
!training/loveda_semantic/data/**/
!training/loveda_semantic/data/**/*.yaml
!training/loveda_semantic/data/**/*.yml
training/loveda_semantic/runs/
training/loveda_semantic/reports/
training/loveda_semantic/*.console.log
training/loveda_semantic/**/*.cache
training/loveda_semantic/tmp/
training/loveda_semantic/temp/

# Generated evaluation artifacts. Keep only small deployment documentation
# and metadata; model binaries are distributed outside normal Git.
training/loveda_semantic/artifacts/*.png

# V2 independent evaluation: exclude reproducible visual/debug output only.
# Keep metrics.json, all evaluation CSV files, evaluation_manifest.json, and
# the frontend model-dashboard V2 JSON/normalized-confusion-matrix asset.
training/loveda_semantic/artifacts/v2_hr1024_yolo26s_sem_full_e50_b4_m1/evaluation/sample_predictions/
training/loveda_semantic/artifacts/v2_hr1024_yolo26s_sem_full_e50_b4_m1/evaluation/confusion_matrix.png
training/loveda_semantic/artifacts/v2_hr1024_yolo26s_sem_full_e50_b4_m1/evaluation/confusion_matrix_normalized.png
training/loveda_semantic/artifacts/v2_hr1024_yolo26s_sem_full_e50_b4_m1/evaluation/per_class_iou_by_domain.png
training/loveda_semantic/artifacts/v2_hr1024_yolo26s_sem_full_e50_b4_m1/evaluation/environment.json

# Downloaded and trained model weights
*.onnx
!training/loveda_semantic/artifacts/baseline_e50_i512_b2/deploy/best_dynamic.onnx

# Keep only the complete current semantic deployment package.
training/loveda_semantic/artifacts/current/**
!training/loveda_semantic/artifacts/
!training/loveda_semantic/artifacts/current/
!training/loveda_semantic/artifacts/current/deploy/
!training/loveda_semantic/artifacts/current/deploy/best.pt
!training/loveda_semantic/artifacts/current/deploy/best_dynamic.onnx
!training/loveda_semantic/artifacts/current/deploy/metadata.json
!training/loveda_semantic/artifacts/current/deploy/environment.json
!training/loveda_semantic/artifacts/current/deploy/manifest.json
!training/loveda_semantic/artifacts/current/deploy/SHA256SUMS.txt
!training/loveda_semantic/artifacts/current/deploy/training_args.yaml

# IDE, OS, and editor state
**/.idea/
**/.DS_Store
**/Thumbs.db
**/Desktop.ini
*.swp
*.swo
